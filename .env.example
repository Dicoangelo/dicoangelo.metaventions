# dicoangelo.com Environment Variables
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================
# REQUIRED - Core Functionality
# ============================================

# Anthropic (for AI chat responses)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Cohere (for query embeddings / semantic search)
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key

# Supabase (for dossier vector search and data storage)
# Get credentials at: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================
# OPTIONAL - Enhanced Features
# ============================================

# PageIndex (Reasoning-Based RAG - replaces Cohere/Supabase)
# Uses tree-structured document retrieval instead of vector similarity
# 98.7% accuracy vs ~30-50% for vector search
# Get your key at: https://dash.pageindex.ai
# PAGEINDEX_API_KEY=pi_your_api_key_here
# PAGEINDEX_DOCUMENT_ID=your_document_id_after_upload

# Deepgram (for streaming speech-to-text)
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-api-key

# ElevenLabs (for high-quality text-to-speech)
# Get your key at: https://elevenlabs.io
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Admin Panel (for JD Analyzer admin access)
# Set a secure password for admin features
ADMIN_PASSWORD=your-secure-admin-password

# ============================================
# OPTIONAL - Production Infrastructure
# ============================================

# Upstash/Vercel KV (for rate limiting)
# Set up at: https://vercel.com/integrations/upstash
# Or create an account at: https://upstash.com
# KV_REST_API_URL=https://your-kv-url.upstash.io
# KV_REST_API_TOKEN=your-kv-token

# Sentry (for error tracking and performance monitoring)
# Set up at: https://sentry.io - create a Next.js project
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# SENTRY_ORG=your-org-name
# SENTRY_PROJECT=your-project-name
# SENTRY_AUTH_TOKEN=your-auth-token

# ============================================
# NOTES
# ============================================
# - Never commit .env.local to version control
# - .env.local is gitignored by default
# - For Vercel deployments, set these in the Vercel dashboard
